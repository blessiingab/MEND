NODE_ENV=development
PORT=5000

# Use DB_PATH in production for a persistent disk mount, for example /var/data/mend.db
DB_PATH=
DB_NAME=mend.db

JWT_SECRET=change_me
JWT_EXPIRE=7d

ADMIN_EMAIL=admin@mend.com
ADMIN_PASSWORD=changeme

SESSION_BOOKING_LEAD_TIME=24
SESSION_DURATION=60

# Optional when hosting the frontend separately.
CLIENT_URL=
APP_URL=
